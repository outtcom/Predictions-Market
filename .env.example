# === Trading Platforms ===

# Polymarket (Polygon EOA wallet private key — API creds derived from this)
POLYMARKET_PRIVATE_KEY=

# Kalshi (session token auth; some accounts use key + secret)
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_EMAIL=
KALSHI_PASSWORD=

# === Signal Sources ===

# Metaculus — primary superforecaster consensus source
METACULUS_API_KEY=

# Good Judgment FutureFirst (enterprise subscription only)
GOODJUDGMENT_API_KEY=

# Manifold Markets — cross-platform arbitrage signal (play money)
MANIFOLD_API_KEY=

# === News & Intel ===

# NewsAPI.org (free tier: 100 req/day)
NEWS_API_KEY=

# Optional: Perigon, NewsData.io, AskNews for higher volume
PERPLEXITY_API_KEY=
ASKNEWS_CLIENT_ID=
ASKNEWS_SECRET=

# === LLM Providers ===

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Notifications ===

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub Pages dashboard URL (set after enabling Pages)
GITHUB_PAGES_URL=

# === System Config ===

MODE=paper          # paper | live
BANKROLL_USD=1000   # starting capital
LOG_LEVEL=INFO
